pipeline {
    agent any

    environment {
        SERVER_IP = "3.110.49.58"
        PROJECT_DIR = "fullstack-devops-project"
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo '📥 Pulling code from GitHub...'
                checkout scm
            }
        }

        stage('Verify Tools') {
            steps {
                echo '🔍 Checking Docker tools...'
                sh 'docker --version'
                sh 'docker-compose --version'
            }
        }

        stage('Build Images') {
            steps {
                echo '🔨 Building Docker images...'
                dir("${PROJECT_DIR}") {
                    sh 'docker-compose build --no-cache'
                }
            }
        }

        stage('Stop Old Containers') {
            steps {
                echo '🛑 Stopping old containers...'
                dir("${PROJECT_DIR}") {
                    sh 'docker-compose down || true'
                }
            }
        }

        stage('Deploy Application') {
            steps {
                echo '🚀 Starting containers...'
                dir("${PROJECT_DIR}") {
                    sh 'docker-compose up -d'
                }
            }
        }

        stage('Verify Containers Running') {
            steps {
                echo '📦 Checking running containers...'
                sh 'docker ps'
            }
        }

        stage('Wait For Services') {
            steps {
                echo '⏳ Waiting for containers to start...'
                sh 'sleep 60'
            }
        }

        stage('Backend Health Check') {
            steps {
                echo '🩺 Checking backend health...'

                sh '''
                i=1
                while [ $i -le 15 ]
                do
                  if curl -f http://localhost:5000/api/health > /dev/null 2>&1; then
                      echo "✅ Backend is healthy!"
                      exit 0
                  fi

                  echo "⌛ Attempt $i/15 failed. Retrying in 5 seconds..."
                  sleep 5
                  i=$((i+1))
                done

                echo "❌ Backend health check FAILED."
                exit 1
                '''
            }
        }

        stage('Frontend Health Check') {
            steps {
                echo '🩺 Checking frontend health...'

                sh '''
                if curl -f http://localhost > /dev/null 2>&1; then
                    echo "✅ Frontend is healthy!"
                else
                    echo "❌ Frontend not responding!"
                    exit 1
                fi
                '''
            }
        }
    }

    post {

        success {
            echo """
            ✅ DEPLOYMENT SUCCESSFUL!
            ==========================================
            Frontend : http://${SERVER_IP}
            Backend  : http://${SERVER_IP}:5000/api/health
            Jenkins  : http://${SERVER_IP}:8080
            ==========================================
            """
        }

        failure {
            echo '❌ Deployment failed! Showing container logs...'

            dir("${PROJECT_DIR}") {
                sh 'docker-compose logs || true'
            }
        }

        always {
            echo '🧹 Cleaning unused Docker resources...'
            sh 'docker system prune -f || true'
        }
    }
}
